# ==============================================================
# Sistema de gestión SaaS - Plantilla de Configuración (.env.example)
# ==============================================================
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo como: .env
#   2. Edita los valores según tu configuración local
#   3. NUNCA subas el archivo .env al repositorio
# ==============================================================

# ── Base de Datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=gestor_pro
DB_USER=root
DB_PASS=
DB_PORT=3306

# ── URL de la Aplicación ──────────────────────────────────────
# Ajusta la ruta según donde hayas colocado el proyecto:
#   En WAMP:  http://localhost/proyectos/proyectoJuevesNewton/proyecto_fixed
#   En XAMPP: http://localhost/proyectos/proyectoJuevesNewton/proyecto_fixed
APP_URL=http://localhost/proyectos/proyectoJuevesNewton/proyecto_fixed

# ── Entorno ───────────────────────────────────────────────────
APP_ENV=development

# ── Clave Secreta (cámbiala por cualquier texto aleatorio) ────
APP_KEY=cambia_este_valor_por_uno_aleatorio
